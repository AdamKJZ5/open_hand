# ============================================================
# Frontend Environment Variables
# ============================================================

# API Configuration
# For production, set the full API URL including protocol and domain
# Example: https://api.openhandcare.com/api
# For development, leave empty to auto-detect (localhost or network IP)
VITE_API_URL=

# API Port (used in development if VITE_API_URL is not set)
# Default: 5001
VITE_API_PORT=5001

# Application Environment
# Options: development, staging, production
VITE_ENV=development

# ============================================================
# Production Deployment Notes
# ============================================================
# 1. Set VITE_API_URL to your production backend URL
# 2. Ensure HTTPS is used in production (https://...)
# 3. Do not commit actual .env file to repository
# 4. Use environment variable injection in CI/CD pipeline
# ============================================================
