# Test Environment Variables
NODE_ENV=test
PORT=5002

# Test Database (automatically cleaned between tests)
MONGO_URI_TEST=mongodb://localhost:27017/openhand-test

# Test JWT Secret
JWT_SECRET=test-jwt-secret-min-32-characters-long-for-testing

# Frontend URL (for email templates in tests)
FRONTEND_URL=http://localhost:5173

# Email Configuration (optional for tests)
EMAIL_SERVICE=gmail
EMAIL_USER=test@example.com
EMAIL_PASSWORD=test-password
EMAIL_FROM=noreply@openhandcare.com

# Twilio (optional for tests - leave empty to skip SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Logging
LOG_LEVEL=error
