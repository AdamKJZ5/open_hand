# =======================
# CORE APPLICATION SETTINGS
# =======================

# Node environment: development, production, or test
NODE_ENV=development

# Server port
PORT=5001

# =======================
# DATABASE CONFIGURATION
# =======================

# MongoDB connection string
# Format: mongodb://localhost:27017/database_name
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb://localhost:27017/openhand

# =======================
# JWT AUTHENTICATION
# =======================

# Secret key for JWT token generation
# IMPORTANT: Must be at least 32 characters in production
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# =======================
# CORS CONFIGURATION
# =======================

# Comma-separated list of allowed origins
# Example: http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# =======================
# EMAIL CONFIGURATION
# =======================

# Email service: 'gmail' or leave empty to use SMTP
EMAIL_SERVICE=gmail

# Gmail Configuration (if using Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Email "From" address (optional, defaults to EMAIL_USER)
EMAIL_FROM=noreply@openhandcare.com

# SMTP Configuration (alternative to Gmail)
# Only needed if EMAIL_SERVICE is not 'gmail'
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# Admin email for notifications
ADMIN_EMAIL=admin@openhandcare.com

# =======================
# TWILIO SMS CONFIGURATION (Optional)
# =======================

# Twilio Account SID and Auth Token
# Leave empty to disable SMS functionality
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =======================
# LOGGING
# =======================

# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# =======================
# SECURITY NOTES
# =======================

# 1. NEVER commit the actual .env file to version control
# 2. Generate strong, unique secrets for JWT_SECRET
# 3. Use environment-specific values for production
# 4. Rotate credentials regularly
# 5. Use Gmail App Passwords (not your actual Gmail password)
# 6. Keep this .env.example file updated when adding new variables
